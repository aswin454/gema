# Server Configurations
PORT=5000
NODE_ENV=development

# Database Configurations
# If local MongoDB is not running, the backend will auto-fallback to a robust In-Memory Mock Database
MONGODB_URI=mongodb://localhost:27017/campusone

# JWT Secret Key
JWT_SECRET=campusone_ai_jwt_secret_secure_key_12984712

# Ollama / Gemma 4 AI API Configuration
# If Ollama is not running, the application will use a smart mock AI fallback service
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma4:e4b

# Optional: Email configurations for password resets and notification alerts
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@campusone.ai
